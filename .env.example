# Supabase project (required)
# Find these in your Supabase project's API settings:
#   https://app.supabase.com/project/<project-id>/settings/api
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# Sentry error reporting (optional, recommended for production).
# Leave blank in local development to skip Sentry initialisation.
# Find at: https://sentry.io/settings/<org>/projects/<project>/keys/
VITE_SENTRY_DSN=
